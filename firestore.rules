rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    match /mainCategories/{id} {
      allow read, write: if isAuth();
    }

    match /subCategories/{id} {
      allow read, write: if isAuth();
    }

    match /productNames/{id} {
      allow read, write: if isAuth();
    }

    match /products/{id} {
      allow read, write: if isAuth();
    }

    match /categories/{id} {
      allow read, write: if isAuth();
    }

    match /inventoryLogs/{id} {
      allow read, create: if isAuth();
      allow update, delete: if false;
    }

    match /auditSessions/{id} {
      allow read, write: if isAuth();
    }

    match /settings/{id} {
      allow read, write: if isAuth();
    }

    match /hierarchyConfig/{id} {
      allow read, write: if isAuth();
    }

    match /hierarchyData/{id} {
      allow read, write: if isAuth();
    }

    // Public read for username → authEmail lookup during login
    match /usernames/{username} {
      allow read: if true;
      allow write: if isAuth();
    }

    // User profiles — readable and writable only by the owner
    match /users/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
